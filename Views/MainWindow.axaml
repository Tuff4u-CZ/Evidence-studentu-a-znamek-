<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StudentEvidence.Views.MainWindow"
        Title="Evidence studentů a známek"
        Width="900" Height="620"
        MinWidth="700" MinHeight="500"
        Background="#1E1E2E">

  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- Hlavička -->
    <Border Grid.Row="0" Background="#313244" Padding="20,16">
      <StackPanel>
        <TextBlock Text="📚 Evidence studentů a známek"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#CDD6F4"/>
        <TextBlock Name="InfoText" Text=""
                   FontSize="12" Foreground="#6C7086" Margin="0,4,0,0"/>
      </StackPanel>
    </Border>

    <!-- Panel hledání a tlačítek -->
    <Border Grid.Row="1" Background="#181825" Padding="16,10">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <TextBox Grid.Column="0"
                 Name="HledaniBox"
                 Watermark="🔍 Hledat studenta nebo třídu..."
                 Background="#313244" Foreground="#CDD6F4"
                 BorderBrush="#45475A" CornerRadius="6"
                 Padding="10,8" Margin="0,0,10,0"/>

        <Button Grid.Column="1" Name="BtnPridat"
                Content="➕ Přidat studenta"
                Background="#A6E3A1" Foreground="#1E1E2E"
                FontWeight="SemiBold" Padding="14,8"
                CornerRadius="6" Margin="0,0,6,0"/>

        <Button Grid.Column="2" Name="BtnStatistiky"
                Content="📊 Statistiky"
                Background="#89B4FA" Foreground="#1E1E2E"
                FontWeight="SemiBold" Padding="14,8"
                CornerRadius="6" Margin="0,0,6,0"/>

        <Button Grid.Column="3" Name="BtnExport"
                Content="💾 Export TXT"
                Background="#FAB387" Foreground="#1E1E2E"
                FontWeight="SemiBold" Padding="14,8"
                CornerRadius="6"/>
      </Grid>
    </Border>

    <!-- Seznam studentů - generováno programově v code-behind -->
    <ScrollViewer Grid.Row="2" Margin="16">
      <ItemsControl Name="StudentiList"/>
    </ScrollViewer>

    <!-- Dolní stavový řádek -->
    <Border Grid.Row="3" Background="#181825" Padding="16,8">
      <TextBlock Name="StatusText"
                 Text="Připraveno"
                 Foreground="#6C7086" FontSize="12"/>
    </Border>

  </Grid>
</Window>
